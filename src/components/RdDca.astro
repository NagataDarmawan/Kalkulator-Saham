---
// Components: reksadana/RdDca.astro
---
<div class="max-w-2xl mx-auto p-4 md:p-6 bg-[#0E1424] border border-gray-800 rounded-xl flex flex-col gap-4">
  <h2 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator DCA Reksadana (Menabung Rutin)</h2>
  
  <div class="bg-[#151C2F] border-l-4 border-emerald-500 p-3 rounded-r-lg border border-gray-800 text-xs text-gray-300">
    Simulasi Dollar Cost Averaging (DCA) untuk melihat efek konsistensi menabung bulanan ditambah efek pertumbuhan bunga majemuk (compounding).
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Tabungan Rutin / Bulan (Rp)</label>
      <input type="text" id="dcaBulanan" placeholder="Contoh: 500.000" class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Target Durasi (Tahun)</label>
      <input type="number" id="dcaTahun" placeholder="Contoh: 5" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div class="md:col-span-2">
      <label class="block text-xs text-gray-400 mb-1">Estimasi Return/CAGR Tahunan (%)</label>
      <input type="number" id="dcaReturn" step="0.1" placeholder="Contoh: 10" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
  </div>
  
  <button onclick="hitungDCA()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg text-sm transition cursor-pointer shadow-md">
    Hitung Proyeksi DCA
  </button>

  <div id="hasilDcaArea" class="hidden space-y-3 p-5 bg-[#0B101D] rounded-xl border border-gray-800">
    <p class="text-xs md:text-sm font-medium uppercase tracking-wider text-gray-400">Proyeksi Akumulasi Dana DCA:</p>
    <div class="text-3xl font-extrabold text-emerald-500" id="outDcaAset">Rp 0</div>
    <div id="badgeDca" class="inline-block px-2.5 py-1 rounded-md text-xs font-bold mt-1 bg-emerald-950/50 text-emerald-400 border border-emerald-900"></div>
    <p class="text-xs md:text-sm text-gray-400 mt-2 border-t pt-3 border-gray-800 leading-relaxed" id="descDca"></p>
  </div>
</div>

<script is:inline>
  function fmtRpDca(str) {
    const numStr = str.replace(/[^,\d]/g, '').toString();
    const split = numStr.split(',');
    const sisa = split[0].length % 3;
    let rp = split[0].substr(0, sisa);
    const rb = split[0].substr(sisa).match(/\d{3}/gi);
    if (rb) { rp += (sisa ? '.' : '') + rb.join('.'); }
    return split[1] !== undefined ? rp + ',' + split[1] : rp;
  }

  const setupDcaFormat = () => {
    const el = document.getElementById('dcaBulanan');
    if (el) el.addEventListener('input', (e) => { e.target.value = fmtRpDca(e.target.value); });
  };
  setupDcaFormat();
  document.addEventListener('astro:page-load', setupDcaFormat);

  function hitungDCA() {
    const pm = parseFloat(document.getElementById('dcaBulanan').value.replace(/\./g, '').replace(/,/g, '.')) || 0;
    const t = parseInt(document.getElementById('dcaTahun').value);
    const r = parseFloat(document.getElementById('dcaReturn').value) / 100 / 12;
    const totalBulan = t * 12;

    if (pm <= 0 || isNaN(r) || r <= 0 || isNaN(t) || t <= 0) {
      alert('Mohon lengkapi semua data input dengan benar.'); return;
    }

    const fv = pm * ((Math.pow(1 + r, totalBulan) - 1) / r) * (1 + r);
    const totalModal = pm * totalBulan;
    const profit = fv - totalModal;

    document.getElementById('hasilDcaArea').classList.remove('hidden');
    document.getElementById('outDcaAset').innerText = `Rp ${Math.round(fv).toLocaleString('id-ID')}`;
    document.getElementById('badgeDca').innerText = `Total Keuntungan: +Rp ${Math.round(profit).toLocaleString('id-ID')}`;
    document.getElementById('descDca').innerHTML = `Anda menabung total pokok <span class="text-white font-bold">Rp ${totalModal.toLocaleString('id-ID')}</span>. Hasil pertumbuhan efek compounding menghasilkan keuntungan bersih sebesar <span class="text-emerald-400 font-bold">Rp ${Math.round(profit).toLocaleString('id-ID')}</span>.`;
  }
</script>

<style>
  /* Menghilangkan tombol spinner up dan down pada input number */
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>