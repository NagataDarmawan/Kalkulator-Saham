---
// Components: reksadana/RdCagr.astro
---
<div class="max-w-2xl mx-auto p-4 md:p-6 bg-[#0E1424] border border-gray-800 rounded-xl flex flex-col gap-4">
  <h2 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Pertumbuhan CAGR & Total Return</h2>
  
  <div class="bg-[#151C2F] border-l-4 border-emerald-500 p-3 rounded-r-lg border border-gray-800 text-xs text-gray-300">
    Menghitung rata-rata pertumbuhan majemuk tahunan (CAGR) serta imbal hasil mutlak (Total Return) berdasarkan riwayat modal awal dan nilai akhir portofolio Anda.
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Modal Awal (Rp)</label>
      <input type="text" id="cagrAwal" placeholder="Contoh: 5.000.000" class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Nilai Investasi Akhir (Rp)</label>
      <input type="text" id="cagrAkhir" placeholder="Contoh: 7.500.000" class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Jarak Waktu (Tahun)</label>
      <input type="number" id="cagrWaktu" placeholder="Contoh: 3" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
  </div>

  <button onclick="hitungCAGR()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg text-sm transition cursor-pointer shadow-md">
    Hitung Kinerja Aset
  </button>

  <div id="hasilCagrArea" class="hidden space-y-3 p-5 bg-[#0B101D] rounded-xl border border-gray-800">
    <p class="text-xs md:text-sm font-medium uppercase tracking-wider text-gray-400">Rerata Pertumbuhan Tahunan (CAGR):</p>
    <div class="text-3xl font-extrabold text-emerald-500" id="outCagr">0%</div>
    <div id="badgeCagr" class="inline-block px-2.5 py-1 rounded-md text-xs font-bold mt-1 bg-emerald-950/50 text-emerald-400 border border-emerald-900"></div>
    <p class="text-xs md:text-sm text-gray-400 mt-2 border-t pt-3 border-gray-800 leading-relaxed" id="descCagr"></p>
  </div>
</div>

<script is:inline>
  function fmtRpCagr(str) {
    const numStr = str.replace(/[^,\d]/g, '').toString();
    const split = numStr.split(',');
    const sisa = split[0].length % 3;
    let rp = split[0].substr(0, sisa);
    const rb = split[0].substr(sisa).match(/\d{3}/gi);
    if (rb) { rp += (sisa ? '.' : '') + rb.join('.'); }
    return split[1] !== undefined ? rp + ',' + split[1] : rp;
  }

  const setupCagrFormat = () => {
    ['cagrAwal', 'cagrAkhir'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('input', (e) => { e.target.value = fmtRpCagr(e.target.value); });
    });
  };
  setupCagrFormat();
  document.addEventListener('astro:page-load', setupCagrFormat);

  function hitungCAGR() {
    const awal = parseFloat(document.getElementById('cagrAwal').value.replace(/\./g, '').replace(/,/g, '.')) || 0;
    const akhir = parseFloat(document.getElementById('cagrAkhir').value.replace(/\./g, '').replace(/,/g, '.')) || 0;
    const t = parseFloat(document.getElementById('cagrWaktu').value);

    if (awal <= 0 || akhir <= 0 || isNaN(t) || t <= 0) {
      alert('Mohon isi parameter nilai modal awal/akhir dengan valid.'); return;
    }

    const totalReturn = ((akhir - awal) / awal) * 100;
    const cagr = (Math.pow((akhir / awal), (1 / t)) - 1) * 100;

    document.getElementById('hasilCagrArea').classList.remove('hidden');
    document.getElementById('outCagr').innerHTML = `${cagr.toFixed(2)}% <span class="text-xs text-gray-500 font-normal">/ Tahun</span>`;
    document.getElementById('badgeCagr').innerText = `Total Return Aktual: +${totalReturn.toFixed(1)}%`;
    document.getElementById('descCagr').innerHTML = `Pertumbuhan absolut total modal Anda dari awal investasi adalah <span class="text-emerald-400 font-bold">${totalReturn.toFixed(1)}%</span>, yang setara dengan akselerasi tahunan konstan sebesar <span class="text-emerald-400 font-bold">${cagr.toFixed(2)}%</span>.`;
  }
</script>

<style>
  /* Menghilangkan tombol spinner up dan down pada input number */
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>