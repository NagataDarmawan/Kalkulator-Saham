<div id="ara-arb-feature" class="w-full h-full flex flex-col gap-4">
  
  <div class="w-full flex-1 bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4 min-h-0">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2 flex-none">Hitung ARA & ARB Beruntun (Fraksi BEI)</h3>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 pb-2 flex-none">
      <div>
        <label class="block text-xs md:text-sm text-gray-400 mb-1">Harga Penutupan</label>
        <input type="number" id="hargaSebut" placeholder="Contoh: 5000" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>
      
      <div>
        <label class="block text-xs md:text-sm text-gray-400 mb-1">Pilih Tipe Batasan</label>
        <select id="tipeBatas" class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500 cursor-pointer">
          <option value="ARA" class="bg-[#0E1424]">ARA (Auto Reject Atas)</option>
          <option value="ARB" class="bg-[#0E1424]">ARB (Auto Reject Bawah)</option>
        </select>
      </div>

      <div>
        <label class="block text-xs md:text-sm text-gray-400 mb-1">Jumlah Hari Beruntun</label>
        <input type="number" id="jumlahHari" value="5" min="1" max="10" placeholder="Maksimal 10" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>

      <div class="flex items-end sm:col-span-2 md:col-span-1">
        <button id="btnHitung" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg transition cursor-pointer text-sm shadow-md">
          Hitung Batas Harga
        </button>
      </div>
    </div>

    <div id="tabelHasilContainer" class="hidden w-full flex-1 border border-gray-800 rounded-xl overflow-y-auto overflow-x-auto bg-[#0B101D] no-scrollbar ios-scroll min-h-0">
      <table class="w-full text-left border-collapse table-fixed min-w-[280px]">
        <thead class="sticky top-0 z-10">
          <tr class="border-b border-gray-800 bg-[#12192C]">
            <th class="p-3 md:p-4 text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider text-center w-1/4">HARI</th>
            <th class="p-3 md:p-4 text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider text-center w-1/4">PERSENTASE</th>
            <th id="thTarget" class="p-3 md:p-4 text-xs md:text-sm font-bold uppercase tracking-wider text-center w-2/4 text-emerald-400">PROYEKSI HARGA</th>
          </tr>
        </thead>
        <tbody id="tabelBody">
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  const btnHitung = document.getElementById('btnHitung');
  
  if (btnHitung) {
    btnHitung.addEventListener('click', () => {
      const hargaInput = document.getElementById('hargaSebut') as HTMLInputElement;
      const tipeSelect = document.getElementById('tipeBatas') as HTMLSelectElement;
      const hariInput = document.getElementById('jumlahHari') as HTMLInputElement;
      const tabelContainer = document.getElementById('tabelHasilContainer');
      const tabelBody = document.getElementById('tabelBody');
      const thTarget = document.getElementById('thTarget');

      let hargaBerjalan = parseFloat(hargaInput.value);
      let tipe = tipeSelect.value;
      let hari = parseInt(hariInput.value) || 1;

      if (!hargaBerjalan || hargaBerjalan <= 0) {
        alert('Masukkan harga saham yang valid!');
        return;
      }

      if (hari < 1) hari = 1;
      if (hari > 10) hari = 10;
      hariInput.value = hari.toString();

      // Atur warna dan teks Header Tabel berdasarkan pilihan dropdown
      if (thTarget) {
        if (tipe === 'ARA') {
          thTarget.innerText = 'PROYEKSI HARGA ARA';
          thTarget.className = "p-3 md:p-4 text-xs md:text-sm font-bold uppercase tracking-wider text-center w-2/4 text-emerald-400";
        } else {
          thTarget.innerText = 'PROYEKSI HARGA ARB';
          thTarget.className = "p-3 md:p-4 text-xs md:text-sm font-bold uppercase tracking-wider text-center w-2/4 text-rose-500";
        }
      }

      if (tabelBody) tabelBody.innerHTML = '';

      // Fungsi penentu persentase regulasi bursa BEI
      const dapatkanPersentase = (price: number) => {
        if (price <= 200) return 0.35;
        if (price <= 5000) return 0.25;
        return 0.20;
      };

      for (let i = 1; i <= hari; i++) {
        let pct = dapatkanPersentase(hargaBerjalan);
        let infoPersen = `+${(pct * 100)}%`;
        let warnaTeks = "text-emerald-400";

        if (tipe === 'ARA') {
          hargaBerjalan = Math.floor(hargaBerjalan * (1 + pct));
          warnaTeks = "text-emerald-400";
          infoPersen = `+${(pct * 100)}%`;
        } else {
          hargaBerjalan = Math.floor(hargaBerjalan * (1 - pct));
          if (hargaBerjalan < 50) hargaBerjalan = 50;
          warnaTeks = "text-rose-400";
          infoPersen = `-${(pct * 100)}%`;
        }

        const row = document.createElement('tr');
        row.className = "border-b border-gray-800/60 hover:bg-[#12192C] transition font-bold text-xs md:text-sm text-center";
        
        row.innerHTML = `
          <td class="p-3 md:p-4 text-gray-400">Hari ke-${i}</td>
          <td class="p-3 md:p-4 text-gray-300 font-semibold">${infoPersen}</td>
          <td class="p-3 md:p-4 ${warnaTeks} whitespace-nowrap">Rp ${hargaBerjalan.toLocaleString('id-ID')}</td>
        `;
        
        tabelBody?.appendChild(row);
      }

      tabelContainer?.classList.remove('hidden');
    });
  }
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
  
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .ios-scroll {
    -webkit-overflow-scrolling: touch;
  }
</style>