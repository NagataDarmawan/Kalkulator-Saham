<div id="ara-arb-feature" class="w-full h-full flex flex-col gap-4">
  
  <div class="w-full flex-none bg-[#0E1424] border border-gray-800 p-4 rounded-xl flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div class="text-xs md:text-sm font-semibold tracking-wider text-emerald-400 uppercase">
      MASUKKAN FEE JUAL & BELI BROKER
    </div>
    <div class="flex flex-wrap items-center gap-4 text-sm">
      <div class="flex items-center gap-2">
        <label class="text-gray-400">Fee Beli (%)</label>
        <input type="number" id="feeBeli" value="0.15" step="0.01" class="no-spinner w-20 bg-[#151C2F] border border-gray-700 rounded px-2 py-1 text-center font-bold text-white focus:outline-none focus:border-emerald-500" />
      </div>
      <div class="flex items-center gap-2">
        <label class="text-gray-400">Fee Jual (%)</label>
        <input type="number" id="feeJual" value="0.25" step="0.01" class="no-spinner w-20 bg-[#151C2F] border border-gray-700 rounded px-2 py-1 text-center font-bold text-white focus:outline-none focus:border-emerald-500" />
      </div>
    </div>
  </div>

  <div class="w-full flex-1 bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4 min-h-0">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2 flex-none">Hitung ARA & ARB Beruntun (Fraksi BEI)</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pb-2 flex-none">
      <div>
        <label class="block text-xs md:text-sm text-gray-400 mb-1">Harga Penutupan Sebelumnya</label>
        <input type="number" id="hargaSebut" placeholder="Contoh: 5000" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white focus:outline-none focus:border-emerald-500" />
      </div>
      
      <div>
        <label class="block text-xs md:text-sm text-gray-400 mb-1">Jumlah Hari ARA/ARB Jilid</label>
        <input type="number" id="jumlahHari" value="5" min="1" max="10" placeholder="Maksimal 10" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white focus:outline-none focus:border-emerald-500" />
      </div>

      <div class="flex items-end">
        <button id="btnHitung" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2 px-4 rounded transition cursor-pointer text-sm md:text-base">
          Hitung Batas Harga
        </button>
      </div>
    </div>

    <div id="tabelHasilContainer" class="hidden w-full flex-1 border border-gray-800 rounded-xl overflow-y-auto overflow-x-auto bg-[#0B101D] no-scrollbar ios-scroll min-h-0">
      <table class="w-full text-left border-collapse table-fixed min-w-[280px]">
        <thead class="sticky top-0 z-10">
          <tr class="border-b border-gray-800 bg-[#12192C]">
            <th class="p-3 md:p-4 text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider text-center w-1/3">HARI</th>
            <th class="p-3 md:p-4 text-xs md:text-sm font-bold text-emerald-400 uppercase tracking-wider text-center w-1/3">ARA</th>
            <th class="p-3 md:p-4 text-xs md:text-sm font-bold text-rose-500 uppercase tracking-wider text-center w-1/3">ARB</th>
          </tr>
        </thead>
        <tbody id="tabelBody">
          </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  const btnHitung = document.getElementById('btnHitung');
  
  if (btnHitung) {
    btnHitung.addEventListener('click', () => {
      const hargaInput = document.getElementById('hargaSebut') as HTMLInputElement;
      const hariInput = document.getElementById('jumlahHari') as HTMLInputElement;
      const tabelContainer = document.getElementById('tabelHasilContainer');
      const tabelBody = document.getElementById('tabelBody');

      let hargaAwal = parseFloat(hargaInput.value);
      let hari = parseInt(hariInput.value) || 1;

      if (!hargaAwal || hargaAwal <= 0) {
        alert('Masukkan harga saham yang valid!');
        return;
      }

      if (hari < 1) hari = 1;
      if (hari > 10) hari = 10;
      hariInput.value = hari.toString();

      let hargaAra = hargaAwal;
      let hargaArb = hargaAwal;

      const dapatkanPersentase = (price: number) => {
        if (price <= 200) return 0.35;
        if (price <= 5000) return 0.25;
        return 0.20;
      };

      if (tabelBody) tabelBody.innerHTML = '';

      for (let i = 1; i <= hari; i++) {
        let pctAra = dapatkanPersentase(hargaAra);
        let pctArb = dapatkanPersentase(hargaArb);

        hargaAra = Math.floor(hargaAra * (1 + pctAra));
        
        hargaArb = Math.floor(hargaArb * (1 - pctArb));
        if (hargaArb < 50) hargaArb = 50;

        const row = document.createElement('tr');
        // PERBAIKAN MOBILE: Menggunakan text-xs pada mobile dan md:text-sm pada desktop agar nominal Rp tidak patah baris
        row.className = "border-b border-gray-800/60 hover:bg-[#12192C] transition font-bold text-xs md:text-sm text-center";
        
        row.innerHTML = `
          <td class="p-3 md:p-4 text-gray-400">H+${i}</td>
          <td class="p-3 md:p-4 text-emerald-400 whitespace-nowrap">Rp ${hargaAra.toLocaleString('id-ID')}</td>
          <td class="p-3 md:p-4 text-rose-400 whitespace-nowrap">Rp ${hargaArb.toLocaleString('id-ID')}</td>
        `;
        
        tabelBody?.appendChild(row);
      }

      tabelContainer?.classList.remove('hidden');
    });
  }
</script>

<style>
  /* Menghilangkan spinner up/down input */
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
  
  /* Menghilangkan scrollbar internal tabel demi estetika full dashboard */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* KUNCI UTAMA SMOOTH SCROLLING DI iOS / SAFARI */
  .ios-scroll {
    -webkit-overflow-scrolling: touch;
  }
</style>