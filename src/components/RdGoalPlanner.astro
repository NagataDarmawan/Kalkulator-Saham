---
// Components: reksadana/RdGoalPlanner.astro
---
<div class="max-w-2xl mx-auto p-4 md:p-6 bg-[#0E1424] border border-gray-800 rounded-xl flex flex-col gap-4">
  <h2 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Target Masa Depan (Goal Planner)</h2>
  
  <div class="bg-[#151C2F] border-l-4 border-emerald-500 p-3 rounded-r-lg border border-gray-800 text-xs text-gray-300">
    Menghitung berapa nominal tabungan bulanan yang wajib Anda sisihkan secara rutin untuk mencapai target dana impian Anda.
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Target Dana Impian (Rp)</label>
      <input type="text" id="goalTarget" placeholder="Contoh: 100.000... " class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Target Waktu (Tahun)</label>
      <input type="number" id="goalTahun" placeholder="Contoh: 5" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Estimasi Return (%/Tahun)</label>
      <input type="number" id="goalReturn" step="0.1" placeholder="Contoh: 10" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>
  </div>

  <button onclick="hitungGoal()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg text-sm transition cursor-pointer shadow-md">
    Hitung Anggaran Bulanan
  </button>

  <div id="hasilGoalArea" class="hidden space-y-3 p-5 bg-[#0B101D] rounded-xl border border-gray-800">
    <p class="text-xs md:text-sm font-medium uppercase tracking-wider text-gray-400">Wajib Menabung Sebesar:</p>
    <div class="text-3xl font-extrabold text-emerald-500" id="outGoalBulanan">Rp 0 <span class="text-xs text-gray-500 font-normal">/ Bulan</span></div>
    <div id="badgeGoal" class="inline-block px-2.5 py-1 rounded-md text-xs font-bold mt-1 bg-emerald-950/50 text-emerald-400 border border-emerald-900"></div>
    <p class="text-xs md:text-sm text-gray-400 mt-2 border-t pt-3 border-gray-800 leading-relaxed" id="descGoal"></p>
  </div>
</div>

<script is:inline>
  function fmtRpGoal(str) {
    const numStr = str.replace(/[^,\d]/g, '').toString();
    const split = numStr.split(',');
    const sisa = split[0].length % 3;
    let rp = split[0].substr(0, sisa);
    const rb = split[0].substr(sisa).match(/\d{3}/gi);
    if (rb) { rp += (sisa ? '.' : '') + rb.join('.'); }
    return split[1] !== undefined ? rp + ',' + split[1] : rp;
  }

  const setupGoalFormat = () => {
    const el = document.getElementById('goalTarget');
    if (el) el.addEventListener('input', (e) => { e.target.value = fmtRpGoal(e.target.value); });
  };
  setupGoalFormat();
  document.addEventListener('astro:page-load', setupGoalFormat);

  function hitungGoal() {
    const target = parseFloat(document.getElementById('goalTarget').value.replace(/\./g, '').replace(/,/g, '.')) || 0;
    const t = parseInt(document.getElementById('goalTahun').value);
    const r = parseFloat(document.getElementById('goalReturn').value) / 100 / 12;
    const totalBulan = t * 12;

    if (target <= 0 || isNaN(r) || r <= 0 || isNaN(t) || t <= 0) {
      alert('Mohon isi parameter target dana, durasi, dan return dengan benar.'); return;
    }

    // Formula PMT Sinking Fund (Annuity Due): PMT = Target / [ ((1+r)^n - 1) / r * (1+r) ]
    const pmt = target / (((Math.pow(1 + r, totalBulan) - 1) / r) * (1 + r));
    const totalPokok = pmt * totalBulan;
    const penghematan = target - totalPokok;

    document.getElementById('hasilGoalArea').classList.remove('hidden');
    document.getElementById('outGoalBulanan').innerHTML = `Rp ${Math.round(pmt).toLocaleString('id-ID')} <span class="text-xs text-gray-500 font-normal">/ Bulan</span>`;
    document.getElementById('badgeGoal').innerText = `Total Modal Pokok Anda: Rp ${Math.round(totalPokok).toLocaleString('id-ID')}`;
    document.getElementById('descGoal').innerHTML = `Untuk mencapai target <span class="text-white font-bold">Rp ${target.toLocaleString('id-ID')}</span>, Anda hanya perlu menyetor pokok sebesar <span class="text-emerald-400 font-bold">Rp ${Math.round(totalPokok).toLocaleString('id-ID')}</span>. Sisanya sebesar <span class="text-emerald-400 font-bold">Rp ${Math.round(penghematan).toLocaleString('id-ID')}</span> dipenuhi oleh keuntungan hasil compounding reksadana.`;
  }
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>