<div id="risk-management-feature" class="w-full flex flex-col gap-4">
  <div class="w-full bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Stop Loss & Take Profit</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Harga Entry (Beli)</label>
        <input type="number" id="riskEntry" placeholder="Contoh: 5000" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Batas Maksimal Stop Loss (%)</label>
        <input type="number" id="riskPersenInput" placeholder="Contoh: 3" step="0.5" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-rose-500" />
      </div>
      <div class="flex items-end">
        <button id="btnHitungRisk" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg transition cursor-pointer text-sm shadow-md">
          Generate Trading Plan
        </button>
      </div>
    </div>

    <div id="riskHasilContainer" class="hidden flex flex-col gap-4 border-t border-gray-800 pt-4">
      
      <div class="w-full bg-[#12192C] p-4 rounded-lg border border-gray-800 text-center">
        <div class="text-xs text-gray-400 font-semibold uppercase mb-1 tracking-wider">Rekomendasi Harga Stop Loss</div>
        <div id="riskHargaSL" class="text-lg md:text-xl font-bold text-rose-400">-</div>
      </div>

      <div class="w-full border border-gray-800 rounded-xl overflow-hidden bg-[#0B101D]">
        <table class="w-full text-left border-collapse table-fixed">
          <thead>
            <tr class="border-b border-gray-800 bg-[#12192C]">
              <th class="p-3 text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider text-center w-1/3">Rasio R:R</th>
              <th class="p-3 text-xs md:text-sm font-bold text-emerald-400 uppercase tracking-wider text-center w-1/3">Target Take Profit</th>
              <th class="p-3 text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider text-center w-1/3">Estimasi Gain (%)</th>
            </tr>
          </thead>
          <tbody id="riskTabelBody">
            </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<script>
  document.getElementById('btnHitungRisk')?.addEventListener('click', () => {
    const entryPrice = parseFloat((document.getElementById('riskEntry') as HTMLInputElement).value);
    const persenSL = parseFloat((document.getElementById('riskPersenInput') as HTMLInputElement).value);
    const tabelBody = document.getElementById('riskTabelBody');

    // Validasi data input angka wajib logis
    if (!entryPrice || !persenSL || entryPrice <= 0 || persenSL <= 0) {
      alert('Mohon masukkan harga Entry dan persentase Stop Loss yang valid!');
      return;
    }

    if (persenSL >= 100) {
      alert('Persentase kerugian tidak boleh lebih atau sama dengan 100%!');
      return;
    }

    // Menghitung nominal jarak rugi dan harga Stop Loss awal
    const jarakRugi = entryPrice * (persenSL / 100);
    const hargaSL = entryPrice - jarakRugi;

    // Tampilkan data Stop Loss utama (dibulatkan ke bawah untuk batas aman manajemen risiko)
    document.getElementById('riskHargaSL')!.innerText = `Rp ${Math.floor(hargaSL).toLocaleString('id-ID')}`;

    if (tabelBody) {
      tabelBody.innerHTML = '';

      // Mengkalkulasi skenario target profit kelipatan rasio 1:1, 1:2, dan 1:3
      const rasioPlan = [
        { nama: '1 : 1 (Conservative)', kali: 1 },
        { nama: '1 : 2 (Balanced)', kali: 2 },
        { nama: '1 : 3 (Aggressive)', kali: 3 }
      ];

      rasioPlan.forEach(plan => {
        const targetTP = entryPrice + (jarakRugi * plan.kali);
        const persenTP = persenSL * plan.kali;

        const row = document.createElement('tr');
        row.className = "border-b border-gray-800/60 hover:bg-[#12192C] transition font-bold text-xs md:text-sm text-center";
        row.innerHTML = `
          <td class="p-3 text-gray-400 text-left md:text-center px-4 md:px-0">${plan.nama}</td>
          <td class="p-3 text-emerald-400 whitespace-nowrap">Rp ${Math.round(targetTP).toLocaleString('id-ID')}</td>
          <td class="p-3 text-emerald-500 whitespace-nowrap">+${persenTP.toFixed(2)}%</td>
        `;
        tabelBody.appendChild(row);
      });
    }

    // Buka kontainer hasil agar langsung memanjang penuh ke bawah
    document.getElementById('riskHasilContainer')?.classList.remove('hidden');
  });
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>