<div id="net-profit-feature" class="w-full flex flex-col gap-4">
  <div class="w-full bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Realized Net Profit & Loss</h3>
    
    <div class="bg-[#151C2F] border-l-4 border-emerald-500 p-3 rounded-r-lg border border-gray-800 text-xs text-gray-300 flex flex-col gap-1">
      <p>💸 <span class="text-emerald-400 font-bold">Kalkulator Realized Net Profit & Loss:</span> Fitur untuk menghitung keuntungan atau kerugian bersih yang didapatkan secara riil setelah posisi investasi ditutup atau dijual.</p>
      <p class="text-gray-400 mt-1 italic text-[11px] border-t border-gray-800 pt-1">Sistem ini otomatis mengalkulasikan Return on Investment (ROI) dengan menyertakan potongan beban komisi broker (Fee Beli & Fee Jual) secara aktual.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Harga Beli (Avg Price)</label>
        <input type="number" id="npHargaBeli" placeholder="Contoh: 1000" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Harga Jual (Target Price)</label>
        <input type="number" id="npHargaJual" placeholder="Contoh: 1100" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Jumlah Lot</label>
        <input type="number" id="npLot" placeholder="Contoh: 100" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
      </div>
      <div class="flex items-end">
        <button id="btnHitungNP" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg transition cursor-pointer text-sm shadow-md">
          Hitung Profit / Loss
        </button>
      </div>
    </div>

    <div id="npHasilContainer" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 mt-4 border-t border-gray-800 pt-4">
      <div class="bg-[#12192C] p-4 rounded-lg border border-gray-800 text-center">
        <div class="text-xs text-gray-400 font-semibold uppercase mb-1 tracking-wider">Total Modal Bersih</div>
        <div id="npTotalModal" class="text-md md:text-lg font-bold text-white">-</div>
      </div>
      <div class="bg-[#12192C] p-4 rounded-lg border border-gray-800 text-center">
        <div class="text-xs text-gray-400 font-semibold uppercase mb-1 tracking-wider">Total Penjualan Bersih</div>
        <div id="npTotalJual" class="text-md md:text-lg font-bold text-white">-</div>
      </div>
      <div class="bg-[#12192C] p-4 rounded-lg border border-gray-800 text-center">
        <div class="text-xs text-gray-400 font-semibold uppercase mb-1 tracking-wider">Net Profit / Loss</div>
        <div id="npNetReturn" class="text-md md:text-lg font-bold">-</div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('btnHitungNP')?.addEventListener('click', () => {
    const hargaBeli = parseFloat((document.getElementById('npHargaBeli') as HTMLInputElement).value);
    const hargaJual = parseFloat((document.getElementById('npHargaJual') as HTMLInputElement).value);
    const lot = parseFloat((document.getElementById('npLot') as HTMLInputElement).value);
    
    // KUNCI SINKRONISASI: Menangkap nilai fee dari komponen utama (index.astro) secara global
    const feeBeliPct = parseFloat((document.getElementById('feeBeli') as HTMLInputElement)?.value || '0.15') / 100;
    const feeJualPct = parseFloat((document.getElementById('feeJual') as HTMLInputElement)?.value || '0.25') / 100;

    if (!hargaBeli || !hargaJual || !lot || hargaBeli <= 0 || hargaJual <= 0 || lot <= 0) {
      alert('Mohon isi semua data inputan dengan benar!');
      return;
    }

    // Hitung Sisi Pembelian (Modal + Beban Biaya Broker)
    const nilaiBeliKotor = hargaBeli * lot * 100;
    const nominalFeeBeli = nilaiBeliKotor * feeBeliPct;
    const totalModalBersih = nilaiBeliKotor + nominalFeeBeli;

    // Hitung Sisi Penjualan (Hasil Jual - Potongan Biaya Broker & Pajak Penghasilan)
    const nilaiJualKotor = hargaJual * lot * 100;
    const nominalFeeJual = nilaiJualKotor * feeJualPct;
    const totalJualBersih = nilaiJualKotor - nominalFeeJual;

    // Menghitung Selisih Keuntungan Riil & ROI
    const netProfitLoss = totalJualBersih - totalModalBersih;
    const ROI = (netProfitLoss / totalModalBersih) * 100;

    // Render hasil kalkulasi ke interface UI
    document.getElementById('npTotalModal')!.innerText = `Rp ${Math.round(totalModalBersih).toLocaleString('id-ID')}`;
    document.getElementById('npTotalJual')!.innerText = `Rp ${Math.round(totalJualBersih).toLocaleString('id-ID')}`;
    
    const elementReturn = document.getElementById('npNetReturn')!;
    if (netProfitLoss >= 0) {
      elementReturn.className = "text-md md:text-lg font-bold text-emerald-400";
      elementReturn.innerText = `+Rp ${Math.round(netProfitLoss).toLocaleString('id-ID')} (${ROI.toFixed(2)}%)`;
    } else {
      elementReturn.className = "text-md md:text-lg font-bold text-rose-400";
      elementReturn.innerText = `-Rp ${Math.abs(Math.round(netProfitLoss)).toLocaleString('id-ID')} (${ROI.toFixed(2)}%)`;
    }

    document.getElementById('npHasilContainer')?.classList.remove('hidden');
  });
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>