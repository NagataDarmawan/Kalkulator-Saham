<div id="average-down-feature" class="w-full flex flex-col gap-4">
  <div class="w-full bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Average Down</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-[#12192C] p-4 rounded-lg border border-gray-800 flex flex-col gap-3">
        <span class="text-xs font-bold text-blue-400 uppercase tracking-wide">Kepemilikan Saat Ini (Lama)</span>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Harga Rata-Rata Lama</label>
          <input type="number" id="avgHargaLama" placeholder="Contoh: 1500" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Jumlah Lot Lama</label>
          <input type="number" id="avgLotLama" placeholder="Contoh: 50" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500" />
        </div>
      </div>

      <div class="bg-[#12192C] p-4 rounded-lg border border-gray-800 flex flex-col gap-3">
        <span class="text-xs font-bold text-emerald-400 uppercase tracking-wide">Pembelian Tambahan (Baru)</span>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Harga Beli Baru</label>
          <input type="number" id="avgHargaBaru" placeholder="Contoh: 1200" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Jumlah Lot Baru</label>
          <input type="number" id="avgLotBaru" placeholder="Contoh: 100" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
        </div>
      </div>
    </div>

    <button id="btnHitungAvg" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2.5 rounded-lg transition cursor-pointer text-sm font-semibold shadow-md">
      Hitung Rata-Rata Baru
    </button>

    <div id="avgHasilContainer" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-gray-800 pt-4 text-center">
      <div class="bg-[#151C2F] p-3 rounded border border-gray-800">
        <div class="text-xs text-gray-400 mb-1">Total Lot Gabungan</div>
        <div id="avgTotalLot" class="text-md font-bold text-white">-</div>
      </div>
      <div class="bg-[#151C2F] p-3 rounded border border-gray-800">
        <div class="text-xs text-gray-400 mb-1">Total Modal Gabungan</div>
        <div id="avgTotalModal" class="text-md font-bold text-white">-</div>
      </div>
      <div class="bg-[#151C2F] p-3 rounded border border-gray-800">
        <div class="text-xs text-gray-400 mb-1">Harga Avg Baru Setelah Fee</div>
        <div id="avgHargaFinal" class="text-md font-bold text-emerald-400">-</div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('btnHitungAvg')?.addEventListener('click', () => {
    const hargaLama = parseFloat((document.getElementById('avgHargaLama') as HTMLInputElement).value);
    const lotLama = parseFloat((document.getElementById('avgLotLama') as HTMLInputElement).value);
    const hargaBaru = parseFloat((document.getElementById('avgHargaBaru') as HTMLInputElement).value);
    const lotBaru = parseFloat((document.getElementById('avgLotBaru') as HTMLInputElement).value);
    const feeBeliPct = parseFloat((document.getElementById('feeBeli') as HTMLInputElement)?.value || '0.15') / 100;

    if (!hargaLama || !lotLama || !hargaBaru || !lotBaru) {
      alert('Lengkapi semua parameter harga dan jumlah lot!');
      return;
    }

    const modalLamaKotor = hargaLama * lotLama * 100;
    const modalBaruKotor = hargaBaru * lotBaru * 100;
    const totalModalBersih = (modalLamaKotor + modalBaruKotor) + (modalBaruKotor * feeBeliPct);

    const totalLotGabungan = lotLama + lotBaru;
    const avgHargaFinal = totalModalBersih / (totalLotGabungan * 100);

    document.getElementById('avgTotalLot')!.innerText = `${totalLotGabungan} Lot`;
    document.getElementById('avgTotalModal')!.innerText = `Rp ${Math.round(totalModalBersih).toLocaleString('id-ID')}`;
    document.getElementById('avgHargaFinal')!.innerText = `Rp ${Math.round(avgHargaFinal).toLocaleString('id-ID')}`;

    document.getElementById('avgHasilContainer')?.classList.remove('hidden');
  });
</script>