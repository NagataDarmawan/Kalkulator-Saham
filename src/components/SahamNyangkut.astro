---
// Components: SahamNyangkut.astro
---

<div class="max-w-2xl mx-auto p-4 md:p-6 bg-[#0E1424] border border-gray-800 rounded-xl flex flex-col gap-4">
  <h2 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Evaluasi Saham Nyangkut</h2>
  
  <div class="bg-[#151C2F] border-l-4 border-blue-500 p-4 rounded-r-lg shadow-sm border border-gray-800">
    <div class="flex gap-3">
      <span class="text-xl md:text-2xl">💡</span>
      <div>
        <h3 class="font-bold text-blue-400 text-sm md:text-base">Apa itu Kalkulator Saham Nyangkut?</h3>
        <p class="text-xs md:text-sm text-gray-300 mt-1.5 leading-relaxed">
          Kalkulator ini digunakan untuk menghitung <strong>Biaya Kesempatan (Opportunity Cost)</strong> atau potensi keuntungan yang hilang selama modal Anda tertidur di saham yang stagnan/nyangkut. 
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 pb-2">
    <div>
      <label class="block text-xs md:text-sm text-gray-400 mb-1">Total Modal Nyangkut Saat Ini (Rp)</label>
      <input type="text" id="modalNyangkut" placeholder="Contoh: 100.000.000" class="w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>

    <div>
      <label class="block text-xs md:text-sm text-gray-400 mb-1">Estimasi Return Tahunan Pembanding (%)</label>
      <input type="number" id="targetReturn" placeholder="Contoh: 6 (SBN / Reksadana)" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
    </div>

    <div>
      <label class="block text-xs md:text-sm text-gray-400 mb-1">Berapa Lama Saham Nyangkut?</label>
      <div class="flex gap-2">
        <input type="number" id="durasiNyangkut" value="1" min="1" placeholder="Contoh: 6" class="no-spinner w-2/3 bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
        <select id="satuanWaktu" class="w-1/3 bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500 cursor-pointer">
          <option value="bulan" class="bg-[#0E1424]">Bulan</option>
          <option value="tahun" class="bg-[#0E1424]">Tahun</option>
        </select>
      </div>
    </div>

    <div class="mt-2">
      <button onclick="prosesHitungNyangkut()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 px-4 rounded-lg transition cursor-pointer text-sm shadow-md">
        Hitung Biaya Kesempatan
      </button>
    </div>
  </div>

  <div id="hasilNyangkutArea" class="hidden space-y-3 p-5 bg-[#0B101D] rounded-xl border border-red-950/40">
    <p class="text-xs md:text-sm font-medium text-rose-400/90 uppercase tracking-wider" id="labelOutput">Perkiraan potensi cuan Anda yang hilang:</p>
    <div class="text-3xl font-extrabold text-rose-500" id="hasilOutput">Rp 0</div>
    <p class="text-xs md:text-sm text-gray-400 mt-2 border-t pt-3 border-gray-800 leading-relaxed" id="keteranganNyangkut"></p>
  </div>
</div>

<script is:inline>
  function formatRupiahNyangkut(angka) {
    const numberString = angka.replace(/[^,\d]/g, '').toString();
    const split = numberString.split(',');
    const sisa = split[0].length % 3;
    let rupiah = split[0].substr(0, sisa);
    const ribuan = split[0].substr(sisa).match(/\d{3}/gi);

    if (ribuan) {
      const separator = sisa ? '.' : '';
      rupiah += separator + ribuan.join('.');
    }
    return split[1] !== undefined ? rupiah + ',' + split[1] : rupiah;
  }

  function hapusTitikNyangkut(value) {
    return parseFloat(value.replace(/\./g, '')) || 0;
  }

  const setupAutoFormatNyangkut = () => {
    const modalInput = document.getElementById('modalNyangkut');
    if (modalInput) {
      modalInput.addEventListener('input', (e) => {
        e.target.value = formatRupiahNyangkut(e.target.value);
      });
    }
  };

  // Inisialisasi awal format rupiah
  setupAutoFormatNyangkut();
  document.addEventListener('astro:page-load', setupAutoFormatNyangkut);

  function prosesHitungNyangkut() {
    const modalInput = document.getElementById('modalNyangkut');
    const persenInput = document.getElementById('targetReturn');
    const durasiInput = document.getElementById('durasiNyangkut');
    const satuanSelect = document.getElementById('satuanWaktu');

    if (modalInput && persenInput && durasiInput && satuanSelect) {
      const modal = hapusTitikNyangkut(modalInput.value);
      const persen = parseFloat(persenInput.value);
      const durasi = parseInt(durasiInput.value);
      const satuan = satuanSelect.value;
      
      if (modal <= 0 || isNaN(persen) || persen <= 0 || isNaN(durasi) || durasi <= 0) {
        alert('Mohon isi semua data input dengan benar.');
        return;
      }

      // Hitung faktor porsi waktu
      const faktorWaktu = satuan === 'tahun' ? durasi : (durasi / 12);
      const hasilOpportCost = (modal * persen / 100) * faktorWaktu;

      const hasilArea = document.getElementById('hasilNyangkutArea');
      if (hasilArea) {
        hasilArea.classList.remove('hidden');
      }
      
      const elLabel = document.getElementById('labelOutput');
      const elOutput = document.getElementById('hasilOutput');
      const elKeterangan = document.getElementById('keteranganNyangkut');

      const teksDurasiLengkap = `${durasi} ${satuan}`;

      if (elLabel) {
        elLabel.innerText = `Dalam ${teksDurasiLengkap}, perkiraan potensi cuan Anda yang hilang sebesar:`;
      }

      if (elOutput) {
        elOutput.innerText = `Rp ${Math.round(hasilOpportCost).toLocaleString('id-ID')}`;
      }

      if (elKeterangan) {
        elKeterangan.innerHTML = `
          Artinya, jika modal sebesar <span class="text-white font-bold">Rp ${modal.toLocaleString('id-ID')}</span> yang tersangkut tersebut Anda alihkan ke instrumen dengan return stabil sebesar <span class="text-emerald-400 font-bold">${persen}%</span> per tahun, Anda bisa mengantongi keuntungan bersih sekitar <span class="text-emerald-400 font-bold">Rp ${Math.round(hasilOpportCost).toLocaleString('id-ID')}</span> selama jangka waktu <span class="text-white font-bold">${teksDurasiLengkap}</span> tanpa terombang-ambing ketidakpastian.
        `;
      }
    }
  }
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>