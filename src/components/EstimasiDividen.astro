<div id="dividen-feature" class="w-full flex flex-col gap-4">
  <div class="w-full bg-[#0E1424] border border-gray-800 p-4 md:p-6 rounded-xl flex flex-col gap-4">
    <h3 class="text-md md:text-lg font-bold text-white border-b border-gray-800 pb-2">Kalkulator Estimasi Pendapatan Dividen</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">DPS (Dividen Per Lembar)</label>
        <input type="number" id="divDPS" placeholder="Contoh: 150" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-emerald-500" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-semibold">Jumlah Lot Kepemilikan</label>
        <input type="number" id="divLot" placeholder="Contoh: 100" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-emerald-500" />
      </div>
      <div class="flex items-end">
        <button id="btnHitungDividen" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2 px-4 rounded-lg transition cursor-pointer text-sm">
          Kalkulasi Dividen
        </button>
      </div>
    </div>

    <div id="divHasilContainer" class="hidden flex flex-col gap-4 mt-2 border-t border-gray-800 pt-4">
      <div class="w-full bg-[#12192C] p-4 rounded-lg border border-gray-800 text-center">
        <div class="text-xs text-gray-400 font-semibold uppercase mb-1">Total Dividen Cair Ke RDN</div>
        <div id="divTotalCair" class="text-lg md:text-xl font-bold text-emerald-400">-</div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('btnHitungDividen')?.addEventListener('click', () => {
    const dps = parseFloat((document.getElementById('divDPS') as HTMLInputElement).value);
    const lot = parseFloat((document.getElementById('divLot') as HTMLInputElement).value);

    // Validasi input
    if (!dps || !lot || dps <= 0 || lot <= 0) {
      alert('Mohon isi data DPS dan Jumlah Lot dengan benar!');
      return;
    }

    // Rumus: DPS x (Jumlah Lot x 100 lembar)
    const totalDividenDiterima = dps * (lot * 100); 

    // Tampilkan nominal rupiah hasil pencairan
    document.getElementById('divTotalCair')!.innerText = `Rp ${Math.round(totalDividenDiterima).toLocaleString('id-ID')}`;

    // Munculkan container hasil
    document.getElementById('divHasilContainer')?.classList.remove('hidden');
  });
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>