---
import Layout from '../layouts/Layout.astro';
import AraArb from '../components/AraArb.astro';
import AverageDown from '../components/AverageDown.astro';
import RiskManagement from '../components/RiskManagement.astro';
import NetProfit from '../components/NetProfit.astro';
import EstimasiDividen from '../components/EstimasiDividen.astro';

// Impor komponen pasar global baru yang akan dibuat nanti (pisahkan per file masing-masing)
//import IndexDunia from '../components/tickers/IndexDunia.astro';
//import Commodities from '../components/tickers/Commodities.astro';
//import KursRupiah from '../components/tickers/KursRupiah.astro';
//import SahamDividen from '../components/tickers/SahamDividen.astro';
//import TopMarketCaps from '../components/tickers/TopMarketCaps.astro';

// Pastikan path ini sesuai dengan tempat Anda menyimpan file CSS utama Tailwind v4 Anda
import '../styles/global.css'; 
---

<Layout>
  <div class="w-full min-h-[100dvh] bg-[#090D16] px-0 md:px-0 pb-0 flex flex-col gap-0">
    
    <div>
      <div class="w-full max-w-full px-4 md:px-8 flex items-center justify-center gap-2 py-3">
        <button id="mainTabCalc" class="whitespace-nowrap text-xs md:text-sm font-bold px-5 py-2.5 rounded-lg transition shadow-sm cursor-pointer bg-emerald-600 text-white">
          Kalkulator Saham
        </button>
        <button id="mainTabGlobal" class="whitespace-nowrap text-xs md:text-sm font-bold px-5 py-2.5 rounded-lg text-gray-400 hover:text-emerald-400 transition cursor-pointer">
          Global
        </button>
      </div>
    </div>

    <div id="bodyKalkulator" class="w-full block px-4 md:px-8">
      
      <div class="w-full bg-[#0E1424] border border-gray-800 p-4 rounded-xl flex flex-col gap-3 mt-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-semibold">Fee Beli Sekuritas (%)</label>
            <input type="number" id="feeBeli" value="0.15" step="0.01" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-semibold">Fee Jual Sekuritas (%)</label>
            <input type="number" id="feeJual" value="0.25" step="0.01" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2 mt-1">
          <button id="btnBatalFee" class="w-full bg-gray-800 hover:bg-gray-700 text-gray-300 text-xs font-semibold py-2 rounded-lg transition cursor-pointer text-center">
            Reset (Batal)
          </button>
          <button id="btnSimpanFee" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold py-2 rounded-lg transition cursor-pointer text-center shadow-md">
            Simpan Permanen
          </button>
        </div>
      </div>

      <div class="w-full grid grid-cols-2 sm:flex sm:flex-wrap gap-2 pb-4 border-b border-gray-800 pt-4">
        <button data-tab="ara-arb" class="tab-btn bg-emerald-600 text-white px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center col-span-2 sm:col-span-1">
          ARA / ARB
        </button>
        <button data-tab="net-profit" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
          Net Profit & Loss
        </button>
        <button data-tab="average-down" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
          Average
        </button>
        <button data-tab="risk-management" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
          Risk Management
        </button>
        <button data-tab="dividen" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
          Estimasi Dividen
        </button>
      </div>

      <div id="tab-contents" class="w-full pt-4">
        <div id="content-ara-arb" class="tab-content block w-full">
          <AraArb />
        </div>
        <div id="content-net-profit" class="tab-content hidden w-full">
          <NetProfit />
        </div>
        <div id="content-average-down" class="tab-content hidden w-full">
          <AverageDown />
        </div>
        <div id="content-risk-management" class="tab-content hidden w-full">
          <RiskManagement />
        </div>
        <div id="content-dividen" class="tab-content hidden w-full">
          <EstimasiDividen />
        </div>
      </div>
    </div>

    <div id="bodyGlobal" class="w-full hidden px-4 md:px-8">
      
      <div class="w-full flex items-center gap-2 overflow-x-auto no-scrollbar pb-4 border-b border-gray-800 pt-4 scroll-smooth -webkit-overflow-scrolling-touch">
        <button data-global-tab="index-dunia" class="global-tab-btn bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer whitespace-nowrap">
          Index Dunia
        </button>
        <button data-global-tab="commodities" class="global-tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-4 py-2 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer whitespace-nowrap">
          Commodities
        </button>
        <button data-global-tab="kurs" class="global-tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-4 py-2 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer whitespace-nowrap">
          Kurs
        </button>
        <button data-global-tab="dividen-bei" class="global-tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-4 py-2 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer whitespace-nowrap">
          Saham Dividen
        </button>
        <button data-global-tab="market-caps" class="global-tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-4 py-2 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer whitespace-nowrap">
          Top Market Caps BEI
        </button>
      </div>

      <div id="global-contents" class="w-full pt-4">
        <div id="global-index-dunia" class="global-content block w-full">
          {/* <IndexDunia /> */}
        </div>
        <div id="global-commodities" class="global-content hidden w-full">
          {/* <Commodities /> */}
        </div>
        <div id="global-kurs" class="global-content hidden w-full">
          {/* <KursRupiah /> */}
        </div>
        <div id="global-dividen-bei" class="global-content hidden w-full">
          {/* <SahamDividen /> */}
        </div>
        <div id="global-market-caps" class="global-content hidden w-full">
          {/* <TopMarketCaps /> */}
        </div>
      </div>
    </div>

  </div>
</Layout>

<script>
  // --- REALTIME BURSA STATUS ---
  function updateMarketStatus() {
    const badge = document.getElementById('liveModeBadge');
    if (!badge) return;

    const options = { timeZone: 'Asia/Jakarta', hour12: false };
    const wibDateStr = new Date().toLocaleString('en-US', options);
    const wibDate = new Date(wibDateStr);

    const hari = wibDate.getDay(); 
    const jam = wibDate.getHours();
    const menit = wibDate.getMinutes();

    const waktuSekarangMenit = (jam * 60) + menit;
    const bursaBukaMenit = 9 * 60;       
    const bursaTutupMenit = 16 * 60;     

    const isMarketOpen = (hari >= 1 && hari <= 5) && (waktuSekarangMenit >= bursaBukaMenit && waktuSekarangMenit < bursaTutupMenit);

    if (isMarketOpen) {
      badge.innerText = "Live Mode (Open)";
      badge.className = "text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2.5 py-1 rounded-full font-medium";
    } else {
      badge.innerText = "Market Closed";
      badge.className = "text-xs bg-rose-500/10 text-rose-400 border border-rose-500/20 px-2.5 py-1 rounded-full font-medium";
    }
  }

  // --- CONTROL UTAMA PANEL SWITCHER (KALKULATOR VS GLOBAL) ---
  function initMainSwitcher() {
    const mainTabCalc = document.getElementById('mainTabCalc');
    const mainTabGlobal = document.getElementById('mainTabGlobal');
    const bodyKalkulator = document.getElementById('bodyKalkulator');
    const bodyGlobal = document.getElementById('bodyGlobal');

    mainTabCalc?.addEventListener('click', () => {
      mainTabCalc.classList.add('bg-emerald-600', 'text-white');
      mainTabCalc.classList.remove('text-gray-400', 'hover:text-emerald-400');
      mainTabGlobal?.classList.remove('bg-emerald-600', 'text-white');
      mainTabGlobal?.classList.add('text-gray-400', 'hover:text-emerald-400');

      bodyKalkulator?.classList.replace('hidden', 'block');
      bodyGlobal?.classList.replace('block', 'hidden');
    });

    mainTabGlobal?.addEventListener('click', () => {
      mainTabGlobal.classList.add('bg-emerald-600', 'text-white');
      mainTabGlobal.classList.remove('text-gray-400', 'hover:text-emerald-400');
      mainTabCalc?.classList.remove('bg-emerald-600', 'text-white');
      mainTabCalc?.classList.add('text-gray-400', 'hover:text-emerald-400');

      bodyGlobal?.classList.replace('hidden', 'block');
      bodyKalkulator?.classList.replace('block', 'hidden');
    });
  }

  // --- LOGIKA UTAMA SUB-TAB INTERNAL KALKULATOR ---
  function initSubTabsKalkulator() {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        tabs.forEach(t => {
          t.classList.remove('bg-emerald-600', 'text-white');
          t.classList.add('bg-[#0E1424]', 'text-gray-400');
        });

        tab.classList.remove('bg-[#0E1424]', 'text-gray-400');
        tab.classList.add('bg-emerald-600', 'text-white');

        contents.forEach(content => {
          if (content.id === `content-${targetTab}`) {
            content.classList.replace('hidden', 'block');
          } else {
            content.classList.replace('block', 'hidden');
          }
        });
      });
    });
  }

  // --- LOGIKA UTAMA SUB-TAB INTERNAL GLOBAL ---
  function initSubTabsGlobal() {
    const globalTabs = document.querySelectorAll('.global-tab-btn');
    const globalContents = document.querySelectorAll('.global-content');

    globalTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetGlobalTab = tab.getAttribute('data-global-tab');

        globalTabs.forEach(t => {
          t.classList.remove('bg-emerald-600', 'text-white');
          t.classList.add('bg-[#0E1424]', 'text-gray-400');
        });

        tab.classList.remove('bg-[#0E1424]', 'text-gray-400');
        tab.classList.add('bg-emerald-600', 'text-white');

        globalContents.forEach(content => {
          if (content.id === `global-${targetGlobalTab}`) {
            content.classList.replace('hidden', 'block');
          } else {
            content.classList.replace('block', 'hidden');
          }
        });
      });
    });
  }

  // --- MANAJEMEN DATA FEE SEKURITAS LOCALSTORAGE ---
  const inputFeeBeli = document.getElementById('feeBeli') as HTMLInputElement;
  const inputFeeJual = document.getElementById('feeJual') as HTMLInputElement;
  const btnSimpan = document.getElementById('btnSimpanFee');
  const btnBatal = document.getElementById('btnBatalFee');

  window.addEventListener('DOMContentLoaded', () => {
    updateMarketStatus();
    initMainSwitcher();
    initSubTabsKalkulator();
    initSubTabsGlobal();

    const savedFeeBeli = localStorage.getItem('customFeeBeli');
    const savedFeeJual = localStorage.getItem('customFeeJual');
    if (savedFeeBeli) inputFeeBeli.value = savedFeeBeli;
    if (savedFeeJual) inputFeeJual.value = savedFeeJual;

    setInterval(updateMarketStatus, 60000);
  });

  btnSimpan?.addEventListener('click', () => {
    if (!inputFeeBeli.value || !inputFeeJual.value) {
      alert('Nilai fee tidak boleh kosong!');
      return;
    }
    localStorage.setItem('customFeeBeli', inputFeeBeli.value);
    localStorage.setItem('customFeeJual', inputFeeJual.value);
    alert('Fee sekuritas berhasil disimpan permanen! 👍');
  });

  btnBatal?.addEventListener('click', () => {
    inputFeeBeli.value = "0.15";
    inputFeeJual.value = "0.25";
    localStorage.removeItem('customFeeBeli');
    localStorage.removeItem('customFeeJual');
    alert('Fee dikembalikan ke setelan default reguler (0.15% / 0.25%)');
  });
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>