---
import Layout from '../layouts/Layout.astro';
import AraArb from '../components/AraArb.astro';
import AverageDown from '../components/AverageDown.astro';
import RiskManagement from '../components/RiskManagement.astro';
import NetProfit from '../components/NetProfit.astro';
import EstimasiDividen from '../components/EstimasiDividen.astro';

// Pastikan path ini sesuai dengan tempat Anda menyimpan file CSS utama Tailwind v4 Anda
import '../styles/global.css'; 
---

<Layout>
  <div class="w-full min-h-[100dvh] bg-[#090D16] px-0 md:px-0 pb-0 flex flex-col gap-0">
    
    <div class="w-full bg-[#0E1424] border border-gray-800 p-4 rounded-xl flex flex-col gap-3 mt-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-semibold">Fee Beli Sekuritas (%)</label>
          <input type="number" id="feeBeli" value="0.15" step="0.01" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-semibold">Fee Jual Sekuritas (%)</label>
          <input type="number" id="feeJual" value="0.25" step="0.01" class="no-spinner w-full bg-[#151C2F] border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 mt-1">
        <button id="btnBatalFee" class="w-full bg-gray-800 hover:bg-gray-700 text-gray-300 text-xs font-semibold py-2 rounded-lg transition cursor-pointer text-center">
          Reset (Batal)
        </button>
        <button id="btnSimpanFee" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold py-2 rounded-lg transition cursor-pointer text-center shadow-md">
          Simpan Permanen
        </button>
      </div>
    </div>

    <div class="w-full grid grid-cols-2 sm:flex sm:flex-wrap gap-2 pb-4 border-b border-gray-800 pt-2">
      <button data-tab="ara-arb" class="tab-btn bg-emerald-600 text-white px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center col-span-2 sm:col-span-1">
        ARA / ARB
      </button>
      <button data-tab="net-profit" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
        Net Profit & Loss
      </button>
      <button data-tab="average-down" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
        Average Down
      </button>
      <button data-tab="risk-management" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
        Risk Management
      </button>
      <button data-tab="dividen" class="tab-btn bg-[#0E1424] hover:bg-[#151C2F] text-gray-400 px-3 py-2.5 rounded-lg font-medium text-xs md:text-sm transition cursor-pointer text-center">
        Estimasi Dividen
      </button>
    </div>

    <div id="tab-contents" class="w-full">
      <div id="content-ara-arb" class="tab-content block w-full">
        <AraArb />
      </div>
      
      <div id="content-net-profit" class="tab-content hidden w-full">
        <NetProfit />
      </div>

      <div id="content-average-down" class="tab-content hidden w-full">
        <AverageDown />
      </div>
      
      <div id="content-risk-management" class="tab-content hidden w-full">
        <RiskManagement />
      </div>

      <div id="content-dividen" class="tab-content hidden w-full">
        <EstimasiDividen />
      </div>
    </div>

  </div>
</Layout>

<script>
  const inputFeeBeli = document.getElementById('feeBeli') as HTMLInputElement;
  const inputFeeJual = document.getElementById('feeJual') as HTMLInputElement;
  const btnSimpan = document.getElementById('btnSimpanFee');
  const btnBatal = document.getElementById('btnBatalFee');

  // 1. OTOMATIS LOAD: Saat aplikasi dibuka, cek apakah user punya simpanan fee kustom di HP-nya
  window.addEventListener('DOMContentLoaded', () => {
    const savedFeeBeli = localStorage.getItem('customFeeBeli');
    const savedFeeJual = localStorage.getItem('customFeeJual');

    if (savedFeeBeli) inputFeeBeli.value = savedFeeBeli;
    if (savedFeeJual) inputFeeJual.value = savedFeeJual;
  });

  // 2. LOGIKA SIMPAN: Mengunci angka inputan ke dalam LocalStorage browser
  btnSimpan?.addEventListener('click', () => {
    if (!inputFeeBeli.value || !inputFeeJual.value) {
      alert('Nilai fee tidak boleh kosong!');
      return;
    }
    localStorage.setItem('customFeeBeli', inputFeeBeli.value);
    localStorage.setItem('customFeeJual', inputFeeJual.value);
    alert('Fee sekuritas berhasil disimpan permanen! 👍');
  });

  // 3. LOGIKA BATAL / RESET: Kembalikan ke persentase default bursa reguler
  btnBatal?.addEventListener('click', () => {
    inputFeeBeli.value = "0.15";
    inputFeeJual.value = "0.25";
    localStorage.removeItem('customFeeBeli');
    localStorage.removeItem('customFeeJual');
    alert('Fee dikembalikan ke setelan default reguler ($0.15% / $0.25%)');
  });

  // 4. Logika Switch Tab Konten (Tetap Sama)
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetTab = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('bg-emerald-600', 'text-white');
        t.classList.add('bg-[#0E1424]', 'text-gray-400');
      });

      tab.classList.remove('bg-[#0E1424]', 'text-gray-400');
      tab.classList.add('bg-emerald-600', 'text-white');

      contents.forEach(content => {
        if (content.id === `content-${targetTab}`) {
          content.classList.remove('hidden');
          content.classList.add('block');
        } else {
          content.classList.remove('block');
          content.classList.add('hidden');
        }
      });
    });
  });
</script>

<style>
  .no-spinner::-webkit-outer-spin-button,
  .no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .no-spinner {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>